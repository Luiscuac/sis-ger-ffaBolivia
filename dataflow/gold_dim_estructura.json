{
	"name": "gold_dim_estructura",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_estructura_organizacional",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_estructura",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          id_estructura_origen as integer,",
				"          nivel as string,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    id_estructura AS id_estructura_origen,\\n    nivel,\\n    nombre,\\n    sigla,\\n    tipo\\nFROM silver.tbl_estructura_organizacional',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          sk_estructura as integer,",
				"          id_estructura_origen as integer,",
				"          nivel as string,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_estructura_origen,",
				"          nivel,",
				"          nombre,",
				"          sigla,",
				"          tipo",
				"     )) ~> sink1"
			]
		}
	}
}