{
	"name": "Gold_Fact_Operaciones",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_operaciones",
						"type": "DatasetReference"
					},
					"name": "operaciones"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_unidad",
						"type": "DatasetReference"
					},
					"name": "goldunidad"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_zona_operacion",
						"type": "DatasetReference"
					},
					"name": "goldzonaoperacion"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_fact_operaciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "lookup2"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_operacion as integer,",
				"          id_tipo as integer,",
				"          id_unidad_resp as integer,",
				"          id_zona as integer,",
				"          nombre_operacion as string,",
				"          fecha_inicio as date,",
				"          fecha_fin as date,",
				"          efectivos_desplegados as integer,",
				"          vehiculos_utilizados as integer,",
				"          duracion_dias as integer,",
				"          costo_operacion as decimal(10,2),",
				"          resultado as string,",
				"          detenidos as integer,",
				"          area_km2 as decimal(10,2),",
				"          incidentes as integer,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> operaciones",
				"source(output(",
				"          sk_unidad as integer,",
				"          id_unidad_origen as integer,",
				"          nombre as string,",
				"          codigo as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> goldunidad",
				"source(output(",
				"          sk_zona as integer,",
				"          id_zona_origen as integer,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          nivel_riesgo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> goldzonaoperacion",
				"operaciones, goldunidad lookup(id_unidad_resp == id_unidad_origen,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1, goldzonaoperacion lookup(id_zona == id_zona_origen,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup2",
				"lookup2 select(mapColumn(",
				"          id_operacion,",
				"          nombre_operacion,",
				"          fecha_inicio,",
				"          fecha_fin,",
				"          efectivos_desplegados,",
				"          vehiculos_utilizados,",
				"          duracion_dias,",
				"          costo_operacion,",
				"          resultado,",
				"          detenidos,",
				"          area_km2,",
				"          incidentes,",
				"          sk_unidad,",
				"          sk_zona",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          sk_operacion as integer,",
				"          id_operacion_origen as integer,",
				"          sk_unidad_resp as integer,",
				"          sk_zona as integer,",
				"          sk_fecha_inicio as date,",
				"          sk_fecha_fin as date,",
				"          nombre_operacion as string,",
				"          resultado as string,",
				"          efectivos_desplegados as integer,",
				"          vehiculos_utilizados as integer,",
				"          duracion_dias as integer,",
				"          costo_operacion as decimal(15,2),",
				"          detenidos as integer,",
				"          area_km2 as decimal(10,2),",
				"          incidentes as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_operacion_origen = id_operacion,",
				"          sk_unidad_resp = sk_unidad,",
				"          sk_zona,",
				"          sk_fecha_inicio = fecha_inicio,",
				"          sk_fecha_fin = fecha_fin,",
				"          nombre_operacion,",
				"          resultado,",
				"          efectivos_desplegados,",
				"          vehiculos_utilizados,",
				"          duracion_dias,",
				"          costo_operacion,",
				"          detenidos,",
				"          area_km2,",
				"          incidentes",
				"     )) ~> sink1"
			]
		}
	}
}