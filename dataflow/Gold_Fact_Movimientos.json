{
	"name": "Gold_Fact_Movimientos",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver__movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "silvermovimientos"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_efectivo",
						"type": "DatasetReference"
					},
					"name": "goldefectivo"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_unidad",
						"type": "DatasetReference"
					},
					"name": "goldunidad"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_rango",
						"type": "DatasetReference"
					},
					"name": "goldrango"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_tipo_movimiento",
						"type": "DatasetReference"
					},
					"name": "goldtipomov"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_fact_movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "lookup2"
				},
				{
					"name": "lookup3"
				},
				{
					"name": "lookup4"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_movimiento as integer,",
				"          id_efectivo as integer,",
				"          id_unidad_destino as integer,",
				"          id_rango as integer,",
				"          id_tipo as integer,",
				"          fecha_movimiento as date,",
				"          antiguedad_anios as decimal(10,1),",
				"          salario_mensual as decimal(10,2),",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> silvermovimientos",
				"source(output(",
				"          sk_efectivo as integer,",
				"          id_efectivo_origen as integer,",
				"          nombre as string,",
				"          ci as string,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          estado as string,",
				"          especialidad_nombre as string,",
				"          especialidad_area as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> goldefectivo",
				"source(output(",
				"          sk_unidad as integer,",
				"          id_unidad_origen as integer,",
				"          nombre as string,",
				"          codigo as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> goldunidad",
				"source(output(",
				"          sk_rango as integer,",
				"          id_rango_origen as integer,",
				"          nombre as string,",
				"          categoria as string,",
				"          nivel_jerarquico as integer,",
				"          abreviatura as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> goldrango",
				"source(output(",
				"          sk_tipo_movimiento as integer,",
				"          id_tipo_origen as integer,",
				"          nombre as string,",
				"          descripcion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> goldtipomov",
				"silvermovimientos, goldefectivo lookup(id_efectivo == id_efectivo_origen,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1, goldunidad lookup(id_unidad_destino == id_unidad_origen,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup2",
				"lookup2, goldrango lookup(id_rango == id_rango_origen,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup3",
				"lookup3, goldtipomov lookup(id_tipo == id_tipo_origen,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup4",
				"lookup4 select(mapColumn(",
				"          id_movimiento,",
				"          fecha_movimiento,",
				"          antiguedad_anios,",
				"          salario_mensual,",
				"          sk_efectivo,",
				"          sk_unidad,",
				"          sk_rango,",
				"          sk_tipo_movimiento",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          sk_movimiento as integer,",
				"          id_movimiento_origen as integer,",
				"          sk_efectivo as integer,",
				"          sk_unidad_destino as integer,",
				"          sk_rango as integer,",
				"          sk_tipo_movimiento as integer,",
				"          sk_fecha_movimiento as date,",
				"          antiguedad_anios as decimal(5,1),",
				"          salario_mensual as decimal(12,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_movimiento_origen = id_movimiento,",
				"          sk_efectivo,",
				"          sk_unidad_destino = sk_unidad,",
				"          sk_rango,",
				"          sk_tipo_movimiento,",
				"          sk_fecha_movimiento = fecha_movimiento,",
				"          antiguedad_anios,",
				"          salario_mensual",
				"     )) ~> sink1"
			]
		}
	}
}